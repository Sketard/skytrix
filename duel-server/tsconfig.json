{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/poc-duel.ts",
    "src/test-core.ts",
    "src/test-snapshot.ts",
    "src/solver-poc.ts",
    "src/**/*-smoke-test.ts"
  ]
}
