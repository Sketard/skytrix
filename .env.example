POSTGRES_DB=skytrix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me_with_a_strong_random_secret_min_64_chars
INTERNAL_API_KEY=change_me_with_a_random_key

# Domaine public (utilisé par certbot)
DOMAIN=yourdomain.com

# Chemin vers les certificats TLS montés dans le conteneur front
# Dev  : TLS_CERT_DIR=./certs
# Prod : TLS_CERT_DIR=/etc/letsencrypt/live/yourdomain.com
TLS_CERT_DIR=./certs
