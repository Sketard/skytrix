# BMAD ephemeral artifacts (stories, sprints, retros)
_bmad-output/implementation-artifacts/

# Solver probe/validation raw JSON outputs — reproducible via probe scripts,
# findings are persisted in spike memory docs. Exclude from git to avoid noise.
_bmad-output/planning-artifacts/research/empirical-validation-*-raw.json
duel-server/audit-*.log
duel-server/eval-*.log

# Duel server external data (downloaded at setup, ~100 MB).
# Use `data/*` (not `data/`) so git can re-include specific files —
# a trailing-slash directory exclude cannot be overridden per-file.
duel-server/data/*
!duel-server/data/solver-config.json
!duel-server/data/interruption-weights.json
!duel-server/data/interruption-tags.json
!duel-server/data/handtraps.json
duel-server/node_modules/
duel-server/dist/

